GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# Optional: require this header (X-API-Key) on /api/jobs requests
API_KEY=
PORT=9003
# Public URL this app is reachable at — required to build the pdf_url sent
# in job-completion callbacks (background jobs have no request context).
PUBLIC_BASE_URL=
# Default webhook to POST {"task_id","pdf_url"} / {"task_id","error"} to when
# a job (created with a task_id) finishes. Per-job callback_url overrides this.
CALLBACK_URL=
